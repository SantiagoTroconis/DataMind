# 1. Usamos una imagen base ligera de Python (versión 3.12 para compatibilidad)
FROM python:3.12-slim

# 2. Establecemos el directorio de trabajo dentro del contenedor
WORKDIR /app

# 3. Evitamos que Python genere archivos .pyc y activamos logs en tiempo real
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 4. Copiamos los requisitos e instalamos dependencias
# (Hacemos esto antes de copiar el código para aprovechar la caché de Docker)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copiamos todo el código de la carpeta Core al contenedor
COPY . .

# 6. Exponemos el puerto 5000 (el puerto de Flask)
EXPOSE 5000

# 7. Comando para arrancar la aplicación
# Usamos Gunicorn (que ya tienes en requirements) porque es mejor para producción que "python run.py"
# "run:app" significa: busca el archivo 'run.py' y la variable 'app'
CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--worker-class", "gevent", "run:app"]